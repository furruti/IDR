# Copiar este archivo como .env y cambiar la contraseña.
POSTGRES_DB=idr
POSTGRES_USER=idr_app
POSTGRES_PASSWORD=CAMBIAR_POR_UNA_CLAVE_LARGA
POSTGRES_PORT=5432

# Para backend ejecutado dentro de Docker:
DATABASE_URL=postgresql://idr_app:CAMBIAR_POR_UNA_CLAVE_LARGA@postgres:5432/idr?schema=idr

# Para backend ejecutado directamente en Windows:
# DATABASE_URL=postgresql://idr_app:CAMBIAR_POR_UNA_CLAVE_LARGA@localhost:5432/idr?schema=idr
